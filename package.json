{
  "name": "hosfind-rag-backend",
  "version": "1.0.0",
  "description": "HosFind medical AI — Supabase full-text search, no LLM",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "setup": "node src/setupDb.js",
    "ingest": "node src/ingest.js",
    "dry-run": "node src/ingest.js --dry-run",
    "ingest:rag": "node src/ingest-rag.js",
    "ingest:rag:dry": "node src/ingest-rag.js --dry-run",
    "ingest:rag:test": "node src/ingest-rag.js --limit 50"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "groq-sdk": "^0.3.3",
    "xml2js": "^0.6.2"
  }
}
