# Supabase (same as your app)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# LLM - Use Groq (free) OR OpenAI
# Groq: https://console.groq.com (free tier, very fast)
GROQ_API_KEY=your_groq_api_key

# OpenAI (optional, for embeddings + LLM)
OPENAI_API_KEY=your_openai_api_key

# Which LLM provider to use: "groq" or "openai"
LLM_PROVIDER=groq

# Which embedding provider: "openai" or "local"
# "local" uses a simple TF-IDF fallback (no API needed)
EMBEDDING_PROVIDER=openai

# Server
PORT=3001
